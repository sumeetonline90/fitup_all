# Environment / secrets
.env
*.env
!.env.example

# Generated secret files — contain obfuscated key material derived from .env
# MUST NOT be committed; regenerate with: dart run build_runner build
lib/core/constants/env_config.g.dart

# Firebase config — contains project IDs + public API keys. Excluded for a
# public repo. Set up your own Firebase project and add these locally:
lib/firebase_options.dart
**/google-services.json
**/GoogleService-Info.plist

# Generated code (run `dart run build_runner build` to regenerate)
**/*.g.dart
**/*.freezed.dart
**/*.gr.dart

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
